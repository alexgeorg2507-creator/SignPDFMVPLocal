# ──────────────────────────────────────────────────────────────────
# SignFinder Local — .env
# Скопируй в .env и заполни ТОЛЬКО эти два поля.
# LLM-провайдер и ключ настраиваются в интерфейсе: Настройки → LLM
# ──────────────────────────────────────────────────────────────────

# Внутренний ключ безопасности API — придумай любую строку ≥20 символов
API_KEY=change_me_to_any_long_random_string_here

# Код для входа в интерфейс SignFinder
ACCESS_CODE=1234

# ──────────────────────────────────────────────────────────────────
# Почта для агента — можно также настроить в Настройки → Mail
# ──────────────────────────────────────────────────────────────────
# IMAP_HOST=mail.example.com
# IMAP_PORT=993
# IMAP_USER=signfinder@example.com
# IMAP_PASSWORD=secret
# IMAP_SSL=true

# SMTP (ответные письма)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=signfinder@example.com
# SMTP_PASSWORD=secret

# Папки IMAP (менять только если нужны другие имена)
# FOLDER_IN=SignfinderIn
# FOLDER_GREEN=SignfinderGreen
# FOLDER_YELLOW=SignfinderYellow
# FOLDER_RED=SignfinderRed
# FOLDER_ARCHIVE=SignfinderArchive

# POLL_INTERVAL_SEC=300
# LOG_MAX_ENTRIES=1000
