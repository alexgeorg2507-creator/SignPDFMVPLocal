# ──────────────────────────────────────────────────────────────────
# SignFinder Local Docker — .env
# Скопируй в .env и заполни
# ──────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-api03-...
API_KEY=change_me_local_secret_key_here
ACCESS_CODE=1234

# LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────
# IMAP — для SignFinder Agent (v1.16)
# ──────────────────────────────────────────────────────────────────
IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USER=signfinder@example.com
IMAP_PASSWORD=secret
IMAP_SSL=true

# SMTP (ответные письма, опционально)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=signfinder@example.com
# SMTP_PASSWORD=secret

# Папки IMAP (менять только если нужны другие имена)
# FOLDER_IN=SignfinderIn
# FOLDER_GREEN=SignfinderGreen
# FOLDER_YELLOW=SignfinderYellow
# FOLDER_RED=SignfinderRed
# FOLDER_ARCHIVE=SignfinderArchive

# POLL_INTERVAL_SEC=300
# REPLY_TO_SENDER=false
# LOG_MAX_ENTRIES=1000
